# ════════════════════════════════════════════════════════════════
# RACING NSW · server-side environment variables (Vercel)
# ----------------------------------------------------------------
# These are read by the serverless functions in /api. They are set in
# the Vercel project (Project Settings → Environment Variables), NOT in
# this file and NOT in the app. Copy this file to `.env` for local
# `vercel dev` only; `.env` is gitignored and must never be committed.
#
# Nothing here is ever bundled into the native iOS/Android app — /api
# deploys only to Vercel. The keys stay server-side.
# ════════════════════════════════════════════════════════════════

# ── Racing Australia API (api/racing/[...path].js) ──────────────
# The upstream API key. While this is unset, /api/racing/* returns a
# clear "API key not configured" stub and the app falls back to
# bundled/cached data. Setting it flips the app to live data.
RACING_API_KEY=

# Upstream base URL (no trailing slash). Confirm against the real
# Racing Australia API docs when the key arrives.
RACING_API_BASE=https://api.racingaustralia.horse

# Header the key is sent in upstream. Default `x-api-key`; change if
# Racing Australia expects e.g. `Authorization`. (Confirm with docs.)
RACING_API_AUTH_HEADER=x-api-key

# ── Dash companion (api/dash.js) ────────────────────────────────
# Anthropic API key for the in-app helper. While unset, /api/dash
# returns a stub and Dash falls back to its on-device knowledge base.
ANTHROPIC_API_KEY=

# Optional: override the model Dash uses. Defaults to claude-opus-4-8.
# Set to claude-haiku-4-5 for a cheaper, faster helper.
DASH_MODEL=claude-opus-4-8
